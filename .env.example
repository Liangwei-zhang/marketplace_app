# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/marketplace
DATABASE_URL_SYNC=postgresql://postgres:your_password@localhost:5432/marketplace

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS - List of allowed origins (comma separated)
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3

# S3/MinIO Storage (for image CDN)
S3_ENABLED=false
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=marketplace
S3_PUBLIC_URL=http://localhost:9000/marketplace

# Redis Cache (for performance)
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_ITEMS=300
CACHE_TTL_USER=600
