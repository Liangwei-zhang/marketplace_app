# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/marketplace
DATABASE_URL_SYNC=postgresql://postgres:your_password@localhost:5432/marketplace

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS - List of allowed origins (comma separated)
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
